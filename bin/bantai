#!/usr/bin/env bash
# Passthrough to bun run dev with all arguments forwarded

# Resolve symlinks to find the real script location (needed for global installs)
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  LINK_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$LINK_DIR/$SOURCE"
done
DIR="$(cd "$(dirname "$SOURCE")/.." && pwd)"

exec bun run --conditions=browser --preload "$DIR/node_modules/@opentui/solid/scripts/preload.ts" "$DIR/src/index.ts" "$@"
