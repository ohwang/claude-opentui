{
  "name": "claude-opentui",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "description": "Open-source, drop-in replacement for Claude Code's terminal UI",
  "bin": {
    "claude-opentui": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --conditions=browser ./src/index.ts",
    "dev:mock": "bun run --conditions=browser ./src/index.ts -- --backend mock",
    "test": "bun test --timeout 30000",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "spike": "bun run --conditions=browser ./spike/spike.tsx"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.85",
    "@opentui/core": "0.1.90",
    "@opentui/solid": "0.1.90",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-plugin-solid": "^0.14.5",
    "typescript": "^5.8.0"
  }
}
