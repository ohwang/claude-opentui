{
  "name": "claude-opentui",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "description": "Open-source, drop-in replacement for Claude Code's terminal UI",
  "bin": {
    "claude-opentui": "./bin/claude-opentui",
    "claude-opentui-storybook": "./bin/claude-opentui-storybook"
  },
  "scripts": {
    "dev": "bun run --conditions=browser ./src/index.ts",
    "dev:mock": "bun run --conditions=browser ./src/index.ts -- --backend mock",
    "test": "bun test --timeout 30000",
    "storybook": "bun run --conditions=browser ./src/storybook/index.tsx",
    "dev:storybook": "bun run --conditions=browser --watch ./src/storybook/index.tsx",
    "lint:opentui": "bash scripts/lint-opentui.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.97",
    "@google/gemini-cli-sdk": "../gemini-cli/packages/sdk",
    "@openai/codex-sdk": "^0.118.0",
    "@opentui/core": "0.1.97",
    "@opentui/solid": "0.1.97",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
