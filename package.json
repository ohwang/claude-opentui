{
  "name": "claude-opentui",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "description": "Open-source, drop-in replacement for Claude Code's terminal UI",
  "bin": {
    "claude-opentui": "./bin/claude-opentui"
  },
  "scripts": {
    "dev": "bun run --conditions=browser ./src/index.ts",
    "dev:mock": "bun run --conditions=browser ./src/index.ts -- --backend mock",
    "test": "bun test --timeout 30000",
    "spike": "bun run --conditions=browser ./spike/spike.tsx",
    "lint:opentui": "bash scripts/lint-opentui.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.85",
    "@opentui/core": "0.1.90",
    "@opentui/solid": "0.1.90",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  }
}
