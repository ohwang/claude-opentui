{
  "name": "bantai",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "description": "Open-source terminal UI for agentic coding backends (Claude Code, Codex, ACP, and more)",
  "author": "Odin Wang <ohwxyz@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ohwang/bantai.git"
  },
  "homepage": "https://github.com/ohwang/bantai",
  "bugs": {
    "url": "https://github.com/ohwang/bantai/issues"
  },
  "bin": {
    "bantai": "./bin/bantai",
    "bantai-storybook": "./bin/bantai-storybook"
  },
  "scripts": {
    "dev": "bun run --conditions=browser ./src/index.ts",
    "dev:mock": "bun run --conditions=browser ./src/index.ts -- --backend mock",
    "test": "bun test --timeout 30000",
    "storybook": "bun run --conditions=browser ./src/storybook/index.tsx",
    "dev:storybook": "bun run --conditions=browser --watch ./src/storybook/index.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "bun run lint:opentui && tsc --noEmit",
    "lint:opentui": "bash scripts/lint-opentui.sh",
    "check:tests": "bash scripts/check-test-coverage.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.107",
    "@openai/codex-sdk": "^0.120.0",
    "@opentui/core": "0.1.99",
    "@opentui/solid": "0.1.99",
    "fuzzysort": "^3.1.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2"
  }
}
